{
  "bracketSameLine": true,
  "overrides": [
    {
      "files": "*.html",
      "options": {
        "htmlWhitespaceSensitivity": "css",
        "printWidth": 256
      }
    },
    {
      "files": "*.js",
      "options": {
        "printWidth": 128
      }
    },
    {
      "files": "*.md"
    }
  ]
}
